# Database Configuration
# Get this from your Neon PostgreSQL database
DATABASE_URL=postgresql://username:password@host/database?sslmode=require&channel_binding=require

# Azure Blob Storage Configuration
# Get these credentials from Azure Portal
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccountname;AccountKey=youraccountkey;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER=content

# Google Gemini API Configuration
# Get your API key from https://console.cloud.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Port Configuration
# PORT=54321

# Optional: Environment
# NODE_ENV=development
